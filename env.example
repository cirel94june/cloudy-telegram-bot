# ========== 必填 ==========
TELEGRAM_BOT_TOKEN=你的bot token
TELEGRAM_CHAT_ID=你的私聊ID,群聊ID（逗号分隔，都填上才能回复）
CLAUDE_API_KEY=中转站密钥
CLAUDE_BASE_URL=https://中转站地址/v1
CLAUDE_MODEL=模型名称（逗号分隔可随机轮选，如 gpt-4o,claude-sonnet-4-20250514）

# ========== API格式 ==========
# anthropic = Anthropic原生格式（/messages 接口）
# openai = OpenAI兼容格式（/chat/completions 接口）大部分中转站用这个
API_FORMAT=openai

# ========== 人格 ==========
BOT_NAME=小克
USER_NAME=小猫
BOT_USERNAME=你的bot用户名（不带@，用于群聊@唤醒）
PROMPT_RULES=你的人格prompt，写这里

# ========== 记忆（GitHub Gist）==========
GIST_TOKEN=你的GitHub Personal Access Token
MEMORY_GIST_URL=https://gist.github.com/你的用户名/gist_id（长期记忆）
STATE_GIST_URL=https://gist.github.com/你的用户名/gist_id（私聊历史）
GROUP_STATE_GIST_URL=https://gist.github.com/你的用户名/gist_id（群聊历史）

# ========== 群聊行为 ==========
REPLY_PROBABILITY=0.1
TRIGGER_WORDS=小克,Cloudy（逗号分隔，群里提到这些必回）
COOLDOWN_TIME=120
REACTION_PROBABILITY=0.1

# ========== 微信式短消息 ==========
SPLIT_MESSAGES=true
SPLIT_DELAY_MIN=0.8
SPLIT_DELAY_MAX=2.0

# ========== 时区 ==========
TIMEZONE=Asia/Shanghai

# ========== 语音（可选）==========
# WHISPER_BASE_URL=
# WHISPER_API_KEY=
# WHISPER_MODEL=whisper-1
# EDGE_TTS_URL=
# EDGE_TTS_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
# MINIMAX_VOICE_ZH=
